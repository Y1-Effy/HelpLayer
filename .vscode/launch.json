{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Demo Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/serve.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "help-layer demo server: (http://localhost:5500/demo/)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Build Library",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "build"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
